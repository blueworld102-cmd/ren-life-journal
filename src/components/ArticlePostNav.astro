---
import type { CollectionEntry } from 'astro:content';
import { formatArticleDate } from '@/utils/articles';

interface Props {
	prev?: CollectionEntry<'articles'>;
	next?: CollectionEntry<'articles'>;
}

const { prev, next } = Astro.props;
---

{
	(prev || next) && (
		<nav class="post-nav" aria-label="文章導覽">
			{prev ? (
				<a href={`/articles/${prev.id}/`} class="post-nav-card prev" data-cursor-hover>
					<span class="post-nav-label">← 上一篇</span>
					<span class="post-nav-category">{prev.data.category}</span>
					<span class="post-nav-title">{prev.data.title}</span>
					<time class="post-nav-date" datetime={prev.data.pubDate.toISOString()}>
						{formatArticleDate(prev.data.pubDate)}
					</time>
				</a>
			) : (
				<div class="post-nav-spacer" />
			)}
			{next ? (
				<a href={`/articles/${next.id}/`} class="post-nav-card next" data-cursor-hover>
					<span class="post-nav-label">下一篇 →</span>
					<span class="post-nav-category">{next.data.category}</span>
					<span class="post-nav-title">{next.data.title}</span>
					<time class="post-nav-date" datetime={next.data.pubDate.toISOString()}>
						{formatArticleDate(next.data.pubDate)}
					</time>
				</a>
			) : (
				<div class="post-nav-spacer" />
			)}
		</nav>
	)
}

<style>
	.post-nav {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 0.5px solid #e8ded2;
	}

	.post-nav-card {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		padding: 1.1rem 1.2rem;
		background: #fff;
		border: 0.5px solid #e8ded2;
		border-radius: 14px;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s ease;
	}

	.post-nav-card:hover {
		border-color: rgba(183, 110, 121, 0.45);
	}

	.post-nav-card.next {
		text-align: right;
		align-items: flex-end;
	}

	.post-nav-spacer {
		display: none;
	}

	.post-nav-label {
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		color: var(--color-text-muted);
	}

	.post-nav-category {
		font-size: 0.74rem;
		letter-spacing: 0.08em;
		color: #b76e79;
	}

	.post-nav-title {
		font-family: var(--font-display);
		font-size: 0.98rem;
		font-weight: 600;
		line-height: 1.45;
		color: var(--color-text-main);
	}

	.post-nav-date {
		font-size: 0.74rem;
		color: var(--color-text-muted);
	}

	@media (max-width: 640px) {
		.post-nav {
			grid-template-columns: 1fr;
			margin-top: 2rem;
			padding-top: 1.5rem;
		}

		.post-nav-card {
			padding: 1rem 1.1rem;
			min-height: 44px;
		}

		.post-nav-card.next {
			text-align: left;
			align-items: flex-start;
		}

		.post-nav-title {
			overflow-wrap: break-word;
		}
	}
</style>
