---
import { getActiveExternalLinks } from '@/utils/externalLinks';

interface Props {
	class?: string;
	ariaLabel?: string;
}

const { class: className = '', ariaLabel = '外部連結' } = Astro.props;
const links = getActiveExternalLinks();
---

{
	links.length > 0 && (
		<nav class:list={['external-links', className]} aria-label={ariaLabel}>
			{links.map((link) => (
				<a
					href={link.href}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={`${link.label}（外部連結）`}
				>
					{link.label}
				</a>
			))}
		</nav>
	)
}

<style>
	.external-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.25rem;
	}

	.external-links a {
		font-size: 0.82rem;
		letter-spacing: 0.06em;
		color: var(--color-muted, var(--ink-muted));
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition:
			color 0.2s ease,
			border-color 0.2s ease;
	}

	.external-links a:hover {
		color: var(--color-accent, var(--accent));
		border-bottom-color: var(--color-accent-soft, var(--accent-soft));
	}
</style>
