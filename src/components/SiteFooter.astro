---
import ExternalLinks from './ExternalLinks.astro';
import { siteProfile } from '@/data/siteProfile';
import { getActiveExternalLinks } from '@/utils/externalLinks';

const year = new Date().getFullYear();
const activeLinks = getActiveExternalLinks();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div>
			<p class="footer-brand">{siteProfile.siteTitle}</p>
			<p class="footer-sub">{siteProfile.siteSubtitle}</p>
			<p class="footer-copy">目前在寫：{siteProfile.currentChapter}</p>
			{activeLinks.length > 0 && <ExternalLinks class="footer-external-links" ariaLabel="社群與外部連結" />}
		</div>
		<nav class="footer-nav" aria-label="頁尾導覽">
			<a href="/articles">Journal</a>
			<a href="/photos">Photos</a>
			<a href="/projects">Projects</a>
			<a href="/about">About</a>
		</nav>
	</div>
	<div class="footer-meta">
		<p class="footer-year">© {year} {siteProfile.name} · Life Journal</p>
		{import.meta.env.DEV && (
			<a href="/admin-help" class="footer-admin-link">
				站長指南
			</a>
		)}
	</div>
</footer>

<style>
	.site-footer {
		position: relative;
		z-index: 2;
		border-top: 1px solid var(--color-border);
		padding: 2.5rem 1.25rem calc(3rem + env(safe-area-inset-bottom, 0px));
		color: var(--color-muted);
		font-size: 0.85rem;
	}

	.footer-inner {
		width: min(var(--max-width), calc(100% - 2.5rem));
		margin: 0 auto 1.25rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.footer-brand {
		margin: 0 0 0.15rem;
		font-family: var(--font-title);
		font-size: 1rem;
		color: var(--color-text);
	}

	.footer-sub {
		margin: 0 0 0.35rem;
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		color: var(--color-muted);
	}

	.footer-copy,
	.footer-year {
		margin: 0;
		letter-spacing: 0.06em;
	}

	.footer-copy {
		margin-bottom: 0.5rem;
	}

	.footer-inner :global(.footer-external-links) {
		margin-top: 0.35rem;
	}

	.footer-meta {
		text-align: center;
	}

	.footer-year {
		margin: 0;
		font-size: 0.78rem;
	}

	.footer-admin-link {
		display: inline-block;
		margin-top: 0.35rem;
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		color: var(--color-muted);
		text-decoration: none;
		opacity: 0.65;
		transition: opacity 0.2s ease, color 0.2s ease;
	}

	.footer-admin-link:hover {
		opacity: 1;
		color: var(--color-accent);
	}

	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
	}

	.footer-nav a {
		text-decoration: none;
		color: var(--color-muted);
		letter-spacing: 0.08em;
		transition: color 0.2s ease;
	}

	.footer-nav a:hover {
		color: var(--color-accent);
	}

	@media (max-width: 768px) {
		.site-footer {
			padding: 2rem 16px 2.5rem;
		}

		.footer-inner {
			flex-direction: column;
			gap: 1.25rem;
		}

		.footer-nav {
			gap: 1rem;
		}
	}
</style>
