---
/**
 * Effects.astro — 全站背景花瓣：緩慢漂浮、低調淡粉
 * 掛載於 BaseLayout.astro；自訂游標見 SiteCursor.astro
 */

/** 桌機 14 片、手機 6 片 */
const PETAL_COUNT = 14;

const driftNames = ['petal-float-a', 'petal-float-b', 'petal-float-c'] as const;
const shapeNames = ['is-teardrop', 'is-ellipse', 'is-sakura'] as const;

const petals = Array.from({ length: PETAL_COUNT }, (_, i) => ({
	left: `${((i * 37 + 9) % 90) + 5}%`,
	top: `${((i * 31 + 13) % 78) + 11}%`,
	delay: `${-((i * 2.7) % 24)}s`,
	duration: `${18 + (i % 9) * 2}s`,
	width: `${9 + (i % 5) * 1.8}px`,
	height: `${12 + (i % 4) * 2}px`,
	opacity: 0.22 + (i % 5) * 0.035,
	mobileOpacity: 0.16 + (i % 4) * 0.027,
	drift: driftNames[i % driftNames.length],
	shape: shapeNames[i % shapeNames.length],
	rotate: `${16 + (i % 8) * 7}deg`,
	mobileHidden: i >= 6,
}));
---

<div class="effects-layer sakura-layer" aria-hidden="true">
	{
		petals.map((petal, index) => (
			<span
				class:list={['sakura-petal', petal.shape, { 'is-mobile-hidden': petal.mobileHidden }]}
				data-petal={index + 1}
				style={{
					left: petal.left,
					top: petal.top,
					width: petal.width,
					height: petal.height,
					'--petal-opacity': petal.opacity,
					'--petal-opacity-mobile': petal.mobileOpacity,
					'--petal-rotate': petal.rotate,
					animationDuration: petal.duration,
					animationDelay: petal.delay,
					animationName: petal.drift,
				}}
			/>
		))
	}
</div>

<style is:global>
	.effects-layer,
	.sakura-layer {
		position: fixed;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
		z-index: 1;
	}

	.sakura-petal {
		position: absolute;
		display: block;
		box-sizing: border-box;
		opacity: var(--petal-opacity, 0.28);
		background: linear-gradient(
			160deg,
			rgba(252, 242, 244, 0.92) 0%,
			rgba(241, 221, 225, 0.68) 42%,
			rgba(220, 180, 188, 0.38) 100%
		);
		transform: rotate(var(--petal-rotate, 32deg));
		animation-timing-function: ease-in-out;
		animation-iteration-count: infinite;
		will-change: transform;
	}

	.sakura-petal.is-sakura {
		border-radius: 50% 0 50% 50%;
	}

	.sakura-petal.is-teardrop {
		border-radius: 62% 38% 68% 32%;
	}

	.sakura-petal.is-ellipse {
		border-radius: 52% 48% 46% 54%;
	}

	@media (max-width: 768px) {
		.sakura-petal.is-mobile-hidden {
			display: none;
		}

		.sakura-petal {
			opacity: var(--petal-opacity-mobile, 0.18);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.effects-layer {
			display: none;
		}
	}

	@keyframes petal-float-a {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--petal-rotate, 28deg));
		}
		50% {
			transform: translate3d(12px, -16px, 0) rotate(calc(var(--petal-rotate, 28deg) + 10deg));
		}
	}

	@keyframes petal-float-b {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--petal-rotate, 52deg));
		}
		50% {
			transform: translate3d(-10px, 14px, 0) rotate(calc(var(--petal-rotate, 52deg) - 9deg));
		}
	}

	@keyframes petal-float-c {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--petal-rotate, 18deg));
		}
		33% {
			transform: translate3d(8px, 10px, 0) rotate(calc(var(--petal-rotate, 18deg) + 7deg));
		}
		66% {
			transform: translate3d(-6px, -11px, 0) rotate(calc(var(--petal-rotate, 18deg) - 6deg));
		}
	}
</style>
