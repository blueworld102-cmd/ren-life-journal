---
import { HERO_CTA_LABEL, HERO_SUBTITLE, HERO_TITLE, JAPAN_TOPIC_LABEL } from '@/consts';
import { siteBackgrounds } from '@/data/siteBackgrounds';

const heroChapterBg = siteBackgrounds.heroChapterCard;
---

<section class="hero">
	<div class="hero-content">
		<h1 class="hero-title">{HERO_TITLE}</h1>
		<p class="hero-subtitle">{HERO_SUBTITLE}</p>
		<a href="/articles" class="btn btn-outline" data-cursor-hover>{HERO_CTA_LABEL}</a>
	</div>

	<div class="hero-visual" aria-hidden="true">
		<div
			class="visual-card"
			style={`--card-bg: url('${heroChapterBg.src}')`}
			role="img"
			aria-label={heroChapterBg.alt}
		>
			<div class="visual-tape"></div>
			<p class="visual-chapter">Currently · Japan</p>
			<p class="visual-topic">{JAPAN_TOPIC_LABEL}</p>
			<p class="visual-date">2026 · 06 · 19</p>
			<p class="visual-title">Tokyo · Everyday Notes</p>
			<p class="visual-sub">Working Holiday in Japan</p>
			<div class="visual-stamp">生活</div>
			<div class="visual-note"></div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		gap: var(--space-md);
		align-items: center;
		padding-block: 6rem 5rem;
		margin-bottom: 2rem;
		border-bottom: 0.5px solid #e8ded2;
		background: var(--color-bg);
	}

	.hero-content,
	.hero-visual {
		position: relative;
		z-index: 1;
	}

	.hero-title {
		margin: 0 0 var(--space-sm);
		font-family: var(--font-display);
		font-size: clamp(1.85rem, 4vw, 3rem);
		font-weight: 600;
		line-height: 1.4;
		color: var(--color-text-main);
	}

	.hero-subtitle {
		margin: 0 0 1.75rem;
		max-width: 34rem;
		font-family: var(--font-body);
		font-size: 1rem;
		line-height: 1.85;
		color: var(--color-text-muted);
	}

	.hero-visual {
		display: flex;
		justify-content: flex-end;
		padding: 0.5rem;
	}

	.visual-card {
		position: relative;
		width: min(100%, 340px);
		aspect-ratio: 3 / 4;
		padding: 2rem 1.75rem 1.5rem;
		border: 0.5px solid #e8ded2;
		border-radius: 3px;
		box-shadow: 4px 6px 0 rgba(46, 42, 39, 0.04);
		transform: rotate(1.5deg);
		overflow: hidden;
		isolation: isolate;
	}

	.visual-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: var(--card-bg);
		background-size: cover;
		background-position: center;
		opacity: 0.34;
		z-index: 0;
	}

	.visual-card::after {
		content: '';
		position: absolute;
		inset: 0;
		background: rgba(250, 247, 242, 0.68);
		z-index: 1;
	}

	.visual-card > :not(.visual-card::before):not(.visual-card::after) {
		position: relative;
		z-index: 2;
	}

	.visual-tape,
	.visual-chapter,
	.visual-topic,
	.visual-date,
	.visual-title,
	.visual-sub,
	.visual-stamp,
	.visual-note {
		position: relative;
		z-index: 2;
	}

	.visual-tape {
		position: absolute;
		top: 14px;
		left: 50%;
		width: 72px;
		height: 18px;
		transform: translateX(-50%) rotate(-2deg);
		background: rgba(255, 255, 255, 0.55);
		border: 0.5px solid #e8ded2;
		z-index: 3;
	}

	.visual-chapter {
		margin: 1.25rem 0 0.2rem;
		font-family: var(--font-body);
		font-size: 0.62rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: #b76e79;
	}

	.visual-topic {
		margin: 0 0 0.85rem;
		font-family: var(--font-body);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		color: var(--color-text-muted);
	}

	.visual-date {
		margin: 0 0 1rem;
		font-family: var(--font-body);
		font-size: 0.68rem;
		letter-spacing: 0.22em;
		color: var(--color-text-muted);
	}

	.visual-title {
		margin: 0 0 0.45rem;
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 600;
		line-height: 1.35;
		color: var(--color-text-main);
	}

	.visual-sub {
		margin: 0;
		font-family: var(--font-body);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		color: var(--color-text-muted);
	}

	.visual-stamp {
		position: absolute;
		right: 1.25rem;
		bottom: 2.5rem;
		padding: 0.35rem 0.65rem;
		border: 1px solid rgba(183, 110, 121, 0.45);
		border-radius: 2px;
		font-family: var(--font-display);
		font-size: 0.82rem;
		letter-spacing: 0.2em;
		color: #b76e79;
		transform: rotate(-8deg);
		opacity: 0.85;
		z-index: 3;
	}

	.visual-note {
		position: absolute;
		left: 1.5rem;
		bottom: 1.25rem;
		width: 48px;
		height: 48px;
		background: rgba(255, 255, 255, 0.45);
		border: 0.5px solid #e8ded2;
		transform: rotate(6deg);
		z-index: 3;
	}

	@media (max-width: 1023px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.hero-visual {
			justify-content: flex-start;
		}

		.visual-card {
			width: min(100%, 300px);
			transform: none;
		}
	}

	@media (max-width: 767px) {
		.hero {
			padding-block: 3.25rem 1.75rem;
			margin-bottom: 1.5rem;
		}

		.hero-title {
			font-size: clamp(1.55rem, 6.5vw, 2rem);
		}

		.hero-subtitle {
			margin-bottom: 1.35rem;
			font-size: 0.92rem;
		}

		.hero-visual {
			padding: 0;
			margin-bottom: 0.25rem;
		}

		.visual-card {
			width: 100%;
			max-width: 100%;
			height: 380px;
			max-height: 400px;
			min-height: 0;
			aspect-ratio: unset;
			padding: 1.25rem 1.15rem 2.25rem;
		}

		.visual-chapter {
			margin-top: 0.85rem;
		}

		.visual-topic {
			margin-bottom: 0.55rem;
		}

		.visual-date {
			margin-bottom: 0.65rem;
		}

		.visual-title {
			font-size: 1.12rem;
		}

		.visual-sub {
			font-size: 0.72rem;
		}

		.visual-stamp {
			right: 1rem;
			bottom: 1.65rem;
			padding: 0.28rem 0.5rem;
			font-size: 0.72rem;
			opacity: 0.75;
		}

		.visual-note {
			display: none;
		}

		.hero-content :global(.btn-outline) {
			min-height: 44px;
		}
	}

	@media (max-width: 390px) {
		.hero {
			padding-block: 3rem 1.5rem;
		}

		.visual-card {
			height: 360px;
			max-height: 380px;
		}
	}
</style>
