---
/**
 * Giscus 留言區 — 文章頁底部。
 * 環境變數可覆寫預設值；見 docs/comments-setup-guide.md
 */
interface Props {
	pathname?: string;
}

const { pathname = Astro.url.pathname } = Astro.props;

const repo = import.meta.env.PUBLIC_GISCUS_REPO ?? 'blueworld102-cmd/ren-life-journal';
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID ?? 'R_kgDOS_FvLg';
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY ?? 'Announcements';
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID ?? 'DIC_kwDOS_FvLs4C_d4y';
---

<section class="giscus-comments" aria-label="留言區">
	<h2 class="giscus-title">留言與回應</h2>
	<div class="giscus-mount giscus" data-pathname={pathname} />
	<script
		is:inline
		src="https://giscus.app/client.js"
		data-repo={repo}
		data-repo-id={repoId}
		data-category={category}
		data-category-id={categoryId}
		data-mapping="pathname"
		data-strict="0"
		data-reactions-enabled="1"
		data-emit-metadata="0"
		data-input-position="bottom"
		data-theme="preferred_color_scheme"
		data-lang="zh-TW"
		data-loading="lazy"
		crossorigin="anonymous"
		async
	/>
</section>

<style>
	.giscus-comments {
		margin-top: 2.5rem;
		padding-top: 2rem;
		border-top: 0.5px solid var(--color-border);
	}

	.giscus-title {
		margin: 0 0 1.25rem;
		font-family: var(--font-title);
		font-size: 1.15rem;
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	.giscus-mount {
		min-height: 120px;
	}
</style>
