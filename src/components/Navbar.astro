---
import { SITE_SUBTITLE, SITE_TITLE } from '../consts';
import NavSearch from './NavSearch.astro';

interface Props {
	currentPath: string;
}

const { currentPath } = Astro.props;

const isJapanTopic = Astro.url.search.includes('topic=japan');

const navItems = [
	{ href: '/', label: 'Home', labelZh: '首頁' },
	{ href: '/articles', label: 'Journal', labelZh: '文章' },
	{ href: '/articles?topic=japan', label: 'Japan', labelZh: '日本' },
	{ href: '/photos', label: 'Photos', labelZh: '照片' },
	{ href: '/about', label: 'About', labelZh: '關於' },
];

const isActive = (href: string) => {
	if (href === '/') return currentPath === '/';
	if (href.includes('topic=japan')) {
		return currentPath.startsWith('/articles') && isJapanTopic;
	}
	if (href === '/articles') {
		return currentPath.startsWith('/articles') && !isJapanTopic;
	}
	return currentPath.startsWith(href);
};

const isJournalPage = currentPath.startsWith('/articles');
---

<header class="navbar site-header">
	<div class="navbar-inner">
		<div class="navbar-brand-row">
			<a href="/" class="brand" data-cursor-hover>
				<span class="brand-title">{SITE_TITLE}</span>
				<span class="brand-subtitle">{SITE_SUBTITLE}</span>
			</a>

			{
				!isJournalPage && (
					<a
						href="/articles"
						class="mobile-search-jump"
						aria-label="前往 Journal 搜尋文章"
						data-cursor-hover
					>
						搜尋
					</a>
				)
			}
		</div>

		<nav class="nav-links" aria-label="主要導覽">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class:list={['nav-link', { active: isActive(item.href) }]}
						title={item.labelZh}
						data-cursor-hover
					>
						{item.label}
					</a>
				))
			}
		</nav>

		<div class:list={['search-slot', { 'is-journal': isJournalPage }]}>
			{
				isJournalPage ? (
					<NavSearch inputId="article-search" />
				) : (
					<NavSearch inputId="nav-search" redirectOnSubmit />
				)
			}
		</div>
	</div>
</header>

<style>
	.navbar {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(250, 247, 242, 0.92);
		backdrop-filter: blur(10px);
		border-bottom: 0.5px solid var(--color-border);
		padding-top: env(safe-area-inset-top, 0px);
		overflow-x: hidden;
	}

	.navbar-inner {
		width: min(var(--max-width), 100%);
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--space-sm) 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
	}

	.navbar-brand-row {
		display: contents;
	}

	.mobile-search-jump {
		display: none;
	}

	.brand {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		text-decoration: none;
		flex-shrink: 0;
		min-width: 0;
	}

	.brand-title {
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 600;
		letter-spacing: 0.03em;
		color: var(--color-text-main);
		line-height: 1.2;
	}

	.brand-subtitle {
		font-family: var(--font-body);
		font-size: 0.68rem;
		letter-spacing: 0.14em;
		color: var(--color-text-muted);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: clamp(0.85rem, 2vw, 1.75rem);
		flex: 1;
		justify-content: center;
		min-width: 0;
	}

	.nav-link {
		text-decoration: none;
		font-family: var(--font-body);
		font-size: 0.82rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--color-text-muted);
		padding-bottom: 0.15rem;
		border-bottom: 0.5px solid transparent;
		white-space: nowrap;
		flex-shrink: 0;
		transition: color 0.2s ease, border-color 0.2s ease;
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--color-text-main);
		border-bottom-color: var(--color-primary);
	}

	.search-slot {
		flex-shrink: 0;
		width: 200px;
	}

	.search-slot :global(.nav-search) {
		width: 100%;
	}

	@media (max-width: 768px) {
		.navbar-inner {
			display: grid;
			grid-template-columns: 1fr auto;
			grid-template-areas:
				'brand jump'
				'nav nav'
				'search search';
			align-items: center;
			padding: 0.65rem 16px 0.75rem;
			gap: 0.55rem 0.75rem;
		}

		.navbar-brand-row {
			display: contents;
		}

		.brand {
			grid-area: brand;
		}

		.mobile-search-jump {
			grid-area: jump;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 36px;
			padding: 0.35rem 0.7rem;
			border: 0.5px solid var(--color-border);
			border-radius: 999px;
			background: var(--color-surface);
			font-size: 0.72rem;
			letter-spacing: 0.08em;
			color: var(--color-text-muted);
			text-decoration: none;
			flex-shrink: 0;
		}

		.nav-links {
			grid-area: nav;
			justify-content: flex-start;
			gap: 1rem;
			width: 100%;
			max-width: 100%;
			overflow-x: auto;
			overflow-y: hidden;
			padding-bottom: 0.2rem;
			-webkit-overflow-scrolling: touch;
			scrollbar-width: none;
			mask-image: linear-gradient(to right, #000 92%, transparent);
		}

		.nav-links::-webkit-scrollbar {
			display: none;
		}

		.nav-link {
			font-size: 0.74rem;
			letter-spacing: 0.12em;
		}

		.brand-title {
			font-size: 0.95rem;
		}

		.brand-subtitle {
			font-size: 0.58rem;
			letter-spacing: 0.1em;
		}

		.search-slot {
			grid-area: search;
			width: 100%;
			display: none;
		}

		.search-slot.is-journal {
			display: block;
		}
	}
</style>
