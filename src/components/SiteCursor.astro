---
/** 桌機書寫感游標 — 淡玫瑰墨點 + hover 章印框 + click SVG 玫瑰綻放 */
---

<div class="site-cursor-layer" aria-hidden="true">
	<div id="cursor-dot" class="site-cursor-dot"></div>
	<div id="cursor-ring" class="site-cursor-ring"></div>
</div>

<style is:global>
	.site-cursor-layer {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 9999;
	}

	.site-cursor-dot,
	.site-cursor-ring {
		position: fixed;
		top: 0;
		left: 0;
		pointer-events: none;
		will-change: transform;
	}

	.site-cursor-dot {
		width: 5px;
		height: 5px;
		border-radius: 50%;
		background: rgba(183, 110, 121, 0.72);
		box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.35);
		transform: translate3d(-100px, -100px, 0) translate(-50%, -50%);
		opacity: 0;
		transition:
			width 0.18s ease,
			height 0.18s ease,
			background 0.18s ease,
			opacity 0.18s ease;
	}

	.site-cursor-dot.is-visible {
		opacity: 1;
	}

	.site-cursor-dot.is-hover {
		width: 4px;
		height: 4px;
		background: rgba(183, 110, 121, 0.58);
	}

	.site-cursor-dot.is-click {
		width: 3px;
		height: 3px;
		background: rgba(183, 110, 121, 0.85);
	}

	.site-cursor-ring {
		width: 30px;
		height: 30px;
		border: 1px solid rgba(183, 110, 121, 0.42);
		border-radius: 4px;
		background: rgba(241, 221, 225, 0.06);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.25);
		transform: translate3d(-100px, -100px, 0) translate(-50%, -50%) scale(1);
		opacity: 0;
		transition:
			opacity 0.2s ease,
			transform 0.2s ease,
			border-color 0.2s ease;
	}

	.site-cursor-ring.is-visible {
		opacity: 1;
	}

	.site-cursor-ring.is-click {
		transform: translate3d(var(--ring-x, -100px), var(--ring-y, -100px), 0)
			translate(-50%, -50%) scale(0.88);
		border-color: rgba(183, 110, 121, 0.55);
	}

	.rose-bloom {
		position: fixed;
		width: 30px;
		height: 30px;
		transform: translate(-50%, -50%);
		pointer-events: none;
		z-index: 9998;
		animation: rose-svg-bloom 580ms ease-out forwards;
	}

	.rose-bloom svg {
		display: block;
		width: 100%;
		height: 100%;
		overflow: visible;
	}

	.rose-bloom .rose-svg-petal {
		transform-origin: 24px 24px;
		transform-box: fill-box;
	}

	@keyframes rose-svg-bloom {
		0% {
			transform: translate(-50%, -50%) scale(0.2);
			opacity: 0;
		}
		18% {
			opacity: 0.72;
		}
		65% {
			transform: translate(-50%, -50%) scale(1);
			opacity: 0.55;
		}
		100% {
			transform: translate(-50%, -50%) scale(1.06);
			opacity: 0;
		}
	}

	@media (min-width: 1024px) and (pointer: fine) and (prefers-reduced-motion: no-preference) {
		*,
		*::before,
		*::after {
			cursor: none !important;
		}
	}

	@media (max-width: 1023px) {
		.site-cursor-layer,
		.site-cursor-dot,
		.site-cursor-ring,
		.rose-bloom {
			display: none !important;
		}
	}

	@media (prefers-reduced-motion: reduce), (pointer: coarse) {
		.site-cursor-layer,
		.site-cursor-dot,
		.site-cursor-ring,
		.rose-bloom {
			display: none !important;
		}
	}
</style>

<script>
	const lerp = (a: number, b: number, t: number) => a + (b - a) * t;
	const ROSE_PETALS = 8;
	const ROSE_LIFETIME_MS = 620;
	const SVG_NS = 'http://www.w3.org/2000/svg';

	(function initSiteCursor() {
		const finePointer = window.matchMedia('(pointer: fine)').matches;
		const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const desktopViewport = window.matchMedia('(min-width: 1024px)').matches;
		if (!finePointer || reducedMotion || !desktopViewport) return;

		const dot = document.getElementById('cursor-dot');
		const ring = document.getElementById('cursor-ring');
		if (!dot || !ring) return;

		let mouseX = -100;
		let mouseY = -100;
		let ringX = -100;
		let ringY = -100;
		let isHover = false;
		let isClick = false;
		let visible = false;
		let rafId = 0;

		const HOVER_SELECTOR =
			"a, button, [role='button'], [data-cursor-hover], input, textarea, select, label";

		function createRoseSVG() {
			const svg = document.createElementNS(SVG_NS, 'svg');
			svg.setAttribute('viewBox', '0 0 48 48');
			svg.setAttribute('aria-hidden', 'true');

			const group = document.createElementNS(SVG_NS, 'g');

			const step = 360 / ROSE_PETALS;
			for (let i = 0; i < ROSE_PETALS; i++) {
				const petal = document.createElementNS(SVG_NS, 'ellipse');
				petal.setAttribute('cx', '24');
				petal.setAttribute('cy', '14');
				petal.setAttribute('rx', '4');
				petal.setAttribute('ry', '6.5');
				petal.setAttribute('fill', 'rgba(241, 221, 225, 0.72)');
				petal.setAttribute('stroke', 'rgba(183, 110, 121, 0.35)');
				petal.setAttribute('stroke-width', '0.5');
				petal.setAttribute('transform', `rotate(${step * i} 24 24)`);
				petal.classList.add('rose-svg-petal');
				group.appendChild(petal);
			}

			const center = document.createElementNS(SVG_NS, 'circle');
			center.setAttribute('cx', '24');
			center.setAttribute('cy', '24');
			center.setAttribute('r', '2.4');
			center.setAttribute('fill', 'rgba(183, 110, 121, 0.55)');
			group.appendChild(center);

			svg.appendChild(group);
			return svg;
		}

		function spawnRoseBloom(x: number, y: number) {
			const bloom = document.createElement('div');
			bloom.className = 'rose-bloom';
			bloom.style.left = `${x}px`;
			bloom.style.top = `${y}px`;
			bloom.setAttribute('aria-hidden', 'true');
			bloom.appendChild(createRoseSVG());

			document.body.appendChild(bloom);

			const removeBloom = () => {
				if (bloom.isConnected) bloom.remove();
			};

			bloom.addEventListener('animationend', removeBloom, { once: true });
			window.setTimeout(removeBloom, ROSE_LIFETIME_MS);
		}

		function setVisible(show: boolean) {
			visible = show;
			dot.classList.toggle('is-visible', show);
		}

		function tick() {
			dot.style.transform = `translate3d(${mouseX}px, ${mouseY}px, 0) translate(-50%, -50%)`;

			ringX = lerp(ringX, mouseX, 0.16);
			ringY = lerp(ringY, mouseY, 0.16);
			ring.style.setProperty('--ring-x', `${ringX}px`);
			ring.style.setProperty('--ring-y', `${ringY}px`);
			ring.style.transform = `translate3d(${ringX}px, ${ringY}px, 0) translate(-50%, -50%) scale(${
				isClick ? 0.88 : 1
			})`;

			dot.classList.toggle('is-hover', isHover);
			dot.classList.toggle('is-click', isClick);
			ring.classList.toggle('is-visible', visible && isHover);
			ring.classList.toggle('is-click', isClick);

			rafId = requestAnimationFrame(tick);
		}

		document.addEventListener('mousemove', (event) => {
			mouseX = event.clientX;
			mouseY = event.clientY;
			if (!visible) setVisible(true);
		});

		document.addEventListener('mouseleave', () => setVisible(false));
		document.addEventListener('mouseenter', () => {
			if (mouseX >= 0) setVisible(true);
		});

		document.addEventListener('mouseover', (event) => {
			isHover = Boolean((event.target as Element).closest(HOVER_SELECTOR));
		});

		document.addEventListener('mouseout', (event) => {
			if ((event.target as Element).closest(HOVER_SELECTOR)) {
				isHover = Boolean(
					(event.relatedTarget as Element | null)?.closest?.(HOVER_SELECTOR),
				);
			}
		});

		document.addEventListener('mousedown', (event) => {
			isClick = true;
			spawnRoseBloom(event.clientX, event.clientY);
		});

		document.addEventListener('mouseup', () => {
			isClick = false;
		});

		rafId = requestAnimationFrame(tick);

		document.addEventListener('astro:before-swap', () => {
			cancelAnimationFrame(rafId);
			document.querySelectorAll('.rose-bloom').forEach((el) => el.remove());
		});
	})();
</script>
