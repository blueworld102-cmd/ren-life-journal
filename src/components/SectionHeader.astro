---
interface Props {
	eyebrow?: string;
	title: string;
	lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<div class="section-header">
	{eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
	<h2 class="section-title">{title}</h2>
	{lead && <p class="section-lead">{lead}</p>}
</div>
