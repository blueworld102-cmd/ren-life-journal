---
import BaseLayout from '@/components/BaseLayout.astro';
import Navbar from '@/components/Navbar.astro';
import { siteProfile } from '@/data/siteProfile';

const pageTitle = `站長更新指南｜${siteProfile.siteTitle}`;
const pageDescription = 'Ren\'s Life Journal 站長操作參考：新增文章、上傳照片、修改 About 與外部連結、部署流程。';
---

<BaseLayout title={pageTitle} description={pageDescription} noindex>
	<Navbar slot="navbar" currentPath={Astro.url.pathname} />

	<header class="page-hero">
		<p class="page-kicker">Site Owner Guide</p>
		<h1 class="page-title">站長更新指南</h1>
		<p class="page-lead">
			這不是後台，無法在網頁上直接編輯內容。請在 Cursor 或本地編輯器修改檔案，再 push 到 GitHub，由 Vercel 自動建置部署。
		</p>
	</header>

	<div class="guide-layout">
		<section class="guide-block">
			<h2>1. 如何新增文章</h2>
			<p>在專案根目錄執行：</p>
			<pre class="code-block"><code>npm run new:article -- "文章標題"</code></pre>
			<p>腳本會自動產生 Markdown 與圖片資料夾（若檔名已存在會報錯，不覆蓋）。</p>
		</section>

		<section class="guide-block">
			<h2>2. 新文章會產生</h2>
			<ul>
				<li><code>src/content/articles/&#123;slug&#125;.md</code> — 文章本體與 frontmatter</li>
				<li><code>public/images/posts/&#123;slug&#125;/</code> — 該篇文章專用圖片資料夾</li>
			</ul>
		</section>

		<section class="guide-block">
			<h2>3. 如何上傳文章照片</h2>
			<p>將圖片放到對應 slug 資料夾，建議命名：</p>
			<ul>
				<li><code>cover.png</code> — 列表與文章頁封面</li>
				<li><code>01.png</code>、<code>02.png</code> — 內文插圖</li>
			</ul>
			<pre class="code-block"><code>public/images/posts/&#123;slug&#125;/cover.png
public/images/posts/&#123;slug&#125;/01.png</code></pre>
		</section>

		<section class="guide-block">
			<h2>4. 如何在文章內插入照片</h2>
			<p>在 Markdown 正文使用（路徑以 <code>/images/</code> 開頭）：</p>
			<pre class="code-block"><code>![圖片描述](/images/posts/&#123;slug&#125;/01.png)</code></pre>
		</section>

		<section class="guide-block">
			<h2>5. 如何發布文章</h2>
			<p>編輯 frontmatter，將 <code>draft</code> 改為 <code>false</code>：</p>
			<pre class="code-block"><code>draft: false</code></pre>
			<p>發布前建議執行 <code>npm run dev</code> 預覽，再以 <code>npm run build</code> 確認無錯誤。</p>
		</section>

		<section class="guide-block">
			<h2>6. 如何修改 About</h2>
			<p>編輯 <code>src/data/siteProfile.ts</code></p>
			<ul>
				<li><code>shortBio</code> / <code>longBio</code> — 簡介</li>
				<li><code>aboutPage</code> — About 頁完整段落</li>
				<li><code>contactLabel</code> — 聯絡方式文字</li>
			</ul>
		</section>

		<section class="guide-block">
			<h2>7. 如何修改首頁文案</h2>
			<p>編輯 <code>src/data/siteCopy.ts</code></p>
			<p>包含 Hero 標題、Latest、Photo Wall、Start Here 區塊標題等。</p>
		</section>

		<section class="guide-block">
			<h2>8. 如何修改 Start Here</h2>
			<p>編輯 <code>src/data/startHere.ts</code></p>
			<p>三張卡片的 title、description、href、linkLabel、image 都在此檔。</p>
		</section>

		<section class="guide-block">
			<h2>9. 如何新增 Instagram / YouTube / Threads</h2>
			<p>編輯 <code>src/data/externalLinks.ts</code>：</p>
			<ol>
				<li>找到對應平台</li>
				<li><code>href</code> 填入完整 URL</li>
				<li><code>isActive</code> 改為 <code>true</code></li>
			</ol>
			<p>啟用後會顯示在 About 頁與 Footer。未啟用時不會出現空連結。</p>
		</section>

		<section class="guide-block">
			<h2>10. 如何部署</h2>
			<ol>
				<li>本地確認 <code>npm run build</code> 通過</li>
				<li><code>git add</code> → <code>git commit</code> → <code>git push</code> 到 GitHub</li>
				<li>Vercel 連接 repo 後會自動 build 並部署</li>
			</ol>
			<p>詳見 <code>docs/deployment-guide.md</code> 與 <code>CONTENT_GUIDE.md</code>。</p>
		</section>

		<aside class="guide-note">
			<p>
				此頁僅供站長參考，未列入主選單。若不想被搜尋引擎索引，已設定 <code>noindex</code>。
			</p>
		</aside>
	</div>
</BaseLayout>

<style>
	.page-hero {
		margin-bottom: 2.5rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--line, var(--color-border));
	}

	.page-kicker {
		margin: 0 0 0.75rem;
		font-size: 0.72rem;
		letter-spacing: 0.28em;
		text-transform: uppercase;
		color: var(--ink-muted, var(--color-muted));
	}

	.page-title {
		margin: 0 0 0.85rem;
		font-family: 'Noto Serif TC', 'Yu Mincho', serif;
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: 600;
		line-height: 1.25;
		letter-spacing: 0.04em;
	}

	.page-lead {
		margin: 0;
		max-width: 40rem;
		color: var(--ink-muted, var(--color-muted));
		font-size: 1rem;
		line-height: 1.8;
	}

	.guide-layout {
		display: grid;
		gap: 0;
		max-width: 42rem;
	}

	.guide-block {
		padding: 2rem 0;
		border-bottom: 1px solid var(--line, var(--color-border));
	}

	.guide-block:first-child {
		padding-top: 0;
	}

	.guide-block h2 {
		margin: 0 0 1rem;
		font-family: 'Noto Serif TC', 'Yu Mincho', serif;
		font-size: 1.2rem;
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	.guide-block p,
	.guide-block li {
		margin: 0 0 0.85rem;
		line-height: 1.85;
		color: var(--ink, var(--color-text));
	}

	.guide-block ul,
	.guide-block ol {
		margin: 0 0 1rem;
		padding-left: 1.35rem;
	}

	.guide-block li:last-child {
		margin-bottom: 0;
	}

	.guide-block code {
		font-size: 0.88em;
		padding: 0.12em 0.35em;
		background: rgba(241, 221, 225, 0.35);
		border-radius: 3px;
	}

	.code-block {
		margin: 0 0 1rem;
		padding: 1rem 1.15rem;
		background: #fff;
		border: 1px solid var(--line, var(--color-border));
		border-radius: 8px;
		overflow-x: auto;
		font-size: 0.86rem;
		line-height: 1.65;
	}

	.code-block code {
		padding: 0;
		background: none;
	}

	.guide-note {
		margin-top: 2rem;
		padding: 1.1rem 1.25rem;
		background: rgba(241, 221, 225, 0.2);
		border: 0.5px solid var(--line, var(--color-border));
		border-radius: 10px;
	}

	.guide-note p {
		margin: 0;
		font-size: 0.86rem;
		line-height: 1.75;
		color: var(--ink-muted, var(--color-muted));
	}

	@media (max-width: 760px) {
		.page-hero {
			margin-bottom: 2rem;
			padding-bottom: 1.5rem;
		}

		.guide-block {
			padding: 1.5rem 0;
		}
	}
</style>
