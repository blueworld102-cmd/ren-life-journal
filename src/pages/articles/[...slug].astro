---
import BaseLayout from '@/components/BaseLayout.astro';
import Navbar from '@/components/Navbar.astro';
import ArticlePostNav from '@/components/ArticlePostNav.astro';
import ArticleRelated from '@/components/ArticleRelated.astro';
import ArticleTopNav from '@/components/ArticleTopNav.astro';
import ArticleBreadcrumb from '@/components/ArticleBreadcrumb.astro';
import ArticleReturnNav from '@/components/ArticleReturnNav.astro';
import ArticleDevEdit from '@/components/ArticleDevEdit.astro';
import ArticleCommentsIntro from '@/components/ArticleCommentsIntro.astro';
import GiscusComments from '@/components/GiscusComments.astro';
import { SITE_TITLE } from '@/consts';
import {
	formatArticleDate,
	getAdjacentArticles,
	getPublishedArticles,
	getRelatedArticles,
	normalizeCoverPosition,
	resolveArticleCover,
	resolveOgImage,
} from '@/utils/articles';
import { type CollectionEntry, getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = (await getCollection('articles')).filter((post) => !post.data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'articles'>;

const post = Astro.props;
const { Content } = await render(post);

const {
	title,
	description,
	pubDate,
	updatedDate,
	cover,
	coverPosition,
	category,
	tags,
	location,
	weather,
	mood,
	readingTime,
} = post.data;

const allArticles = await getCollection('articles');
const published = getPublishedArticles(allArticles);
const { prev, next } = getAdjacentArticles(published, post.id);
const related = getRelatedArticles(published, post);

const coverData = resolveArticleCover(cover);
const coverAlt = coverData.alt ?? title;
const coverPos = normalizeCoverPosition(coverPosition);
const ogImage = resolveOgImage(cover);
const pageTitle = `${title}｜${SITE_TITLE}`;

const metaParts = [
	formatArticleDate(pubDate),
	location,
	weather,
	readingTime ? `閱讀 ${readingTime}` : '',
].filter(Boolean);

const metaLine = metaParts.join('｜');
const moodLine = mood ? `心情：${mood}` : '';
---

<BaseLayout
	title={pageTitle}
	description={description}
	image={ogImage}
	ogType="article"
	publishedTime={pubDate.toISOString()}
	modifiedTime={updatedDate?.toISOString()}
	tags={tags}
>
	<Navbar slot="navbar" currentPath={Astro.url.pathname} />

	<article class="article-page">
		<ArticleTopNav />
		<ArticleBreadcrumb category={category} title={title} />

		<header class="article-header">
			<p class="article-eyebrow">{category}</p>
			<h1 class="article-title">{title}</h1>
			<p class="article-description">{description}</p>

			{metaLine && <p class="article-meta-line">{metaLine}</p>}
			{moodLine && <p class="article-mood-line">{moodLine}</p>}

			{
				updatedDate && (
					<p class="article-updated">
						最後更新：{formatArticleDate(updatedDate)}
					</p>
				)
			}

			{
				tags.length > 0 && (
					<ul class="article-tags" aria-label="文章標籤">
						{tags.map((tag) => (
							<li>
								<a href={`/articles?search=${encodeURIComponent(tag)}`}>{tag}</a>
							</li>
						))}
					</ul>
				)
			}
		</header>

		<figure
			class:list={['article-cover', { 'is-fallback': coverData.isFallback }]}
			style={`--cover-position: ${coverPos}`}
		>
			<img
				src={coverData.src}
				alt={coverAlt}
				width="960"
				height="540"
				loading="eager"
				decoding="async"
				style={`object-position: ${coverPos}`}
			/>
		</figure>

		<div class="article-prose">
			<Content />
		</div>

		<ArticleReturnNav />
		<ArticlePostNav prev={prev} next={next} />
		<ArticleCommentsIntro />
		<GiscusComments pathname={`/articles/${post.id}/`} />
		<ArticleRelated articles={related} />
		<ArticleDevEdit slug={post.id} />
	</article>
</BaseLayout>

<style>
	.article-page {
		max-width: 920px;
		margin: 0 auto;
		padding: 0 0 3rem;
	}

	.article-header {
		max-width: 880px;
		margin: 0 auto 1.75rem;
		text-align: left;
	}

	.article-eyebrow {
		margin: 0 0 0.75rem;
		font-family: var(--font-body);
		font-size: 0.76rem;
		letter-spacing: 0.16em;
		color: #b76e79;
	}

	.article-title {
		margin: 0 0 1rem;
		font-family: 'Noto Serif TC', 'Yu Mincho', var(--font-display), serif;
		font-size: clamp(2rem, 4.5vw, 3.5rem);
		font-weight: 600;
		line-height: 1.3;
		letter-spacing: 0.02em;
		color: var(--color-text-main);
	}

	.article-description {
		margin: 0 0 1.25rem;
		max-width: 38rem;
		font-family: var(--font-body);
		font-size: 1.05rem;
		line-height: 1.85;
		color: #7e746b;
	}

	.article-meta-line,
	.article-mood-line {
		margin: 0;
		font-family: var(--font-body);
		font-size: 0.8rem;
		line-height: 1.7;
		letter-spacing: 0.04em;
		color: #8c8279;
	}

	.article-mood-line {
		margin-top: 0.25rem;
	}

	.article-updated {
		margin: 0.65rem 0 0;
		font-size: 0.78rem;
		font-style: italic;
		color: var(--color-text-muted);
	}

	.article-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		list-style: none;
		margin: 1.1rem 0 0;
		padding: 0;
	}

	.article-tags a {
		display: inline-block;
		padding: 0.22rem 0.7rem;
		border: 0.5px solid #e8ded2;
		border-radius: 999px;
		font-size: 0.74rem;
		letter-spacing: 0.04em;
		color: #7e746b;
		text-decoration: none;
		background: #fff;
		transition: border-color 0.2s ease, color 0.2s ease;
	}

	.article-tags a:hover {
		border-color: #b76e79;
		color: #b76e79;
	}

	.article-cover {
		position: relative;
		margin: 0 auto 2.5rem;
		max-width: 880px;
		aspect-ratio: 3 / 2;
		overflow: hidden;
		border: 0.5px solid #e8ded2;
		border-radius: 16px;
		background: #f1dde1;
	}

	.article-cover.is-fallback::after {
		content: '';
		position: absolute;
		inset: 0;
		background: rgba(255, 255, 255, 0.58);
		pointer-events: none;
	}

	.article-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: var(--cover-position, center);
		display: block;
	}

	.article-prose {
		max-width: 720px;
		margin: 0 auto;
		font-family: var(--font-body);
		font-size: 1.0625rem;
		line-height: 1.9;
		color: var(--color-text-main);
	}

	.article-prose :global(h1),
	.article-prose :global(h2),
	.article-prose :global(h3),
	.article-prose :global(h4) {
		font-family: 'Noto Serif TC', 'Yu Mincho', serif;
		font-weight: 600;
		line-height: 1.45;
		letter-spacing: 0.02em;
		color: var(--color-text-main);
		margin: 2.5rem 0 1rem;
	}

	.article-prose :global(h2) {
		font-size: 1.5rem;
		padding-bottom: 0.45rem;
		border-bottom: 0.5px solid #e8ded2;
	}

	.article-prose :global(h3) {
		font-size: 1.25rem;
	}

	.article-prose :global(h4) {
		font-size: 1.08rem;
	}

	.article-prose :global(p) {
		margin: 0 0 1.5rem;
	}

	.article-prose :global(a) {
		color: #b76e79;
		text-decoration: underline;
		text-decoration-color: rgba(183, 110, 121, 0.35);
		text-underline-offset: 3px;
	}

	.article-prose :global(strong) {
		font-weight: 600;
		color: var(--color-text-main);
	}

	.article-prose :global(ul),
	.article-prose :global(ol) {
		margin: 0 0 1.5rem;
		padding-left: 1.35rem;
	}

	.article-prose :global(li) {
		margin-bottom: 0.45rem;
	}

	.article-prose :global(blockquote) {
		margin: 2rem 0;
		padding: 1.1rem 1.3rem;
		border-left: 3px solid rgba(183, 110, 121, 0.55);
		background: rgba(241, 221, 225, 0.28);
		font-family: 'Noto Serif TC', 'Yu Mincho', serif;
		font-size: 1.05rem;
		line-height: 1.8;
		color: #7e746b;
		border-radius: 0 8px 8px 0;
	}

	.article-prose :global(img) {
		display: block;
		width: 100%;
		max-width: 100%;
		height: auto;
		margin: 2rem auto;
		border: 0.5px solid #e8ded2;
		border-radius: 12px;
	}

	.article-prose :global(pre) {
		margin: 1.75rem 0;
		padding: 1.2rem 1.3rem;
		overflow-x: auto;
		background: #fff;
		border: 0.5px solid #e8ded2;
		border-radius: 8px;
		font-size: 0.88rem;
		line-height: 1.65;
	}

	.article-prose :global(code) {
		font-size: 0.9em;
		padding: 0.12em 0.38em;
		background: rgba(255, 255, 255, 0.8);
		border: 0.5px solid #e8ded2;
		border-radius: 4px;
	}

	.article-prose :global(pre code) {
		padding: 0;
		background: none;
		border: none;
	}

	.article-prose :global(hr) {
		margin: 2.5rem 0;
		border: none;
		border-top: 0.5px solid #e8ded2;
	}

	@media (max-width: 768px) {
		.article-page {
			padding: 0 0 2.5rem;
		}

		.article-header {
			margin-bottom: 1.25rem;
		}

		.article-title {
			font-size: clamp(1.55rem, 7vw, 2rem);
		}

		.article-description {
			font-size: 0.98rem;
		}

		.article-meta-line,
		.article-mood-line {
			font-size: 0.76rem;
		}

		.article-cover {
			margin-bottom: 1.75rem;
			border-radius: 12px;
		}

		.article-prose {
			font-size: 1rem;
			line-height: 1.85;
		}

		.article-prose :global(h2) {
			font-size: 1.3rem;
			margin-top: 2rem;
		}

		.article-prose :global(h3) {
			font-size: 1.15rem;
		}
	}
</style>
