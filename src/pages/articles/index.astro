---
import BaseLayout from '@/components/BaseLayout.astro';
import Navbar from '@/components/Navbar.astro';
import SectionHeader from '@/components/SectionHeader.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { JAPAN_TOPIC_LABEL, SITE_DESCRIPTION, SITE_SUBTITLE, SITE_TITLE } from '@/consts';
import {
	getAllCategories,
	getAllTags,
	getPublishedArticles,
	toArticleCardProps,
} from '@/utils/articles';

const allArticles = await getCollection('articles');
const articles = getPublishedArticles(allArticles);
const articleCards = articles.map(toArticleCardProps);
const categories = getAllCategories(articles);
const tags = getAllTags(articles);

const pageTitle = `Journal｜${SITE_TITLE}`;
---

<BaseLayout title={pageTitle} description={SITE_DESCRIPTION}>
	<Navbar slot="navbar" currentPath={Astro.url.pathname} />

	<SectionHeader
		eyebrow="Journal"
		title="全部文章"
		lead="搜尋、篩選你現在需要的內容。支援標題、描述、標籤、地點與心情。"
	/>

	<p class="topic-note">
		目前在寫 <strong>{JAPAN_TOPIC_LABEL}</strong>（{SITE_SUBTITLE}）。未來會加入更多國家的章節。
	</p>

	<div class="filters-panel">
		<div class="chip-group">
			<p class="chip-label">分類</p>
			<div class="chip-row" id="category-filters">
				<button type="button" class="chip is-active" data-filter-category="">全部</button>
				{
					categories.map((category) => (
						<button type="button" class="chip" data-filter-category={category}>
							{category}
						</button>
					))
				}
			</div>
		</div>

		<div class="chip-group">
			<p class="chip-label">標籤</p>
			<div class="chip-row" id="tag-filters">
				<button type="button" class="chip is-active" data-filter-tag="">全部</button>
				{
					tags.map((tag) => (
						<button type="button" class="chip" data-filter-tag={tag}>
							{tag}
						</button>
					))
				}
			</div>
		</div>
	</div>

	<p id="results-count" class="results-count">共 {articleCards.length} 篇文章</p>

	<section id="article-list" class="article-list">
		{articleCards.map((article) => <ArticleCard {...article} />)}
	</section>

	<div id="empty-state" class="empty-state" hidden>
		<h2>找不到相關文章。</h2>
		<p>也許你可以試試：東京生活、打工度假、區役所、雨天、面試。</p>
		<button type="button" class="btn btn-secondary" id="reset-filters">清除篩選</button>
	</div>
</BaseLayout>

<script>
	function initArticleFilters() {
		const searchInput = document.getElementById('article-search') as HTMLInputElement | null;
		const list = document.getElementById('article-list');
		const resultsCount = document.getElementById('results-count');
		const emptyState = document.getElementById('empty-state');
		const resetButton = document.getElementById('reset-filters');
		const categoryButtons = Array.from(
			document.querySelectorAll<HTMLButtonElement>('[data-filter-category]'),
		);
		const tagButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter-tag]'));

		if (!searchInput || !list || !resultsCount || !emptyState) return;

		const cards = Array.from(list.querySelectorAll('[data-article-card]'));
		let activeCategory = '';
		let activeTag = '';
		let activeTopic = '';

		const setActiveChip = (
			buttons: HTMLButtonElement[],
			activeButton: HTMLButtonElement,
			attr: 'data-filter-category' | 'data-filter-tag',
		) => {
			buttons.forEach((button) => {
				button.classList.toggle('is-active', button === activeButton);
			});
			return activeButton.getAttribute(attr) ?? '';
		};

		const applyFilters = () => {
			const query = searchInput.value.trim().toLowerCase();
			let visibleCount = 0;

			cards.forEach((card) => {
				const searchText = card.getAttribute('data-search') ?? '';
				const category = card.getAttribute('data-category') ?? '';
				const tags = (card.getAttribute('data-tags') ?? '').split(',');
				const topic = card.getAttribute('data-topic') ?? '';

				const matchesSearch = !query || searchText.includes(query);
				const matchesCategory = !activeCategory || category === activeCategory;
				const matchesTag = !activeTag || tags.includes(activeTag);
				const matchesTopic = !activeTopic || topic === activeTopic;

				const isVisible = matchesSearch && matchesCategory && matchesTag && matchesTopic;
				card.classList.toggle('is-hidden', !isVisible);
				if (isVisible) visibleCount += 1;
			});

			resultsCount.textContent =
				query || activeCategory || activeTag || activeTopic
					? `找到 ${visibleCount} 篇文章`
					: `共 ${cards.length} 篇文章`;
			emptyState.hidden = visibleCount > 0;
			list.hidden = visibleCount === 0;
		};

		searchInput.addEventListener('input', applyFilters);

		categoryButtons.forEach((button) => {
			button.addEventListener('click', () => {
				activeCategory = setActiveChip(categoryButtons, button, 'data-filter-category');
				applyFilters();
			});
		});

		tagButtons.forEach((button) => {
			button.addEventListener('click', () => {
				activeTag = setActiveChip(tagButtons, button, 'data-filter-tag');
				applyFilters();
			});
		});

		resetButton?.addEventListener('click', () => {
			searchInput.value = '';
			activeTopic = '';
			activeCategory = setActiveChip(
				categoryButtons,
				categoryButtons[0],
				'data-filter-category',
			);
			activeTag = setActiveChip(tagButtons, tagButtons[0], 'data-filter-tag');
			applyFilters();
		});

		const params = new URLSearchParams(window.location.search);
		const categoryParam = params.get('category');
		const searchParam = params.get('search');
		const topicParam = params.get('topic');
		if (categoryParam) {
			const matched = categoryButtons.find(
				(button) => button.getAttribute('data-filter-category') === categoryParam,
			);
			if (matched) {
				activeCategory = setActiveChip(categoryButtons, matched, 'data-filter-category');
			}
		}
		if (searchParam) {
			searchInput.value = searchParam;
		}
		if (topicParam) {
			activeTopic = topicParam.toLowerCase();
		}
		applyFilters();
	}

	initArticleFilters();
</script>

<style>
	.topic-note {
		margin: -0.5rem 0 1.5rem;
		font-size: 0.86rem;
		line-height: 1.7;
		color: var(--color-muted);
	}

	.topic-note strong {
		color: var(--color-text);
		font-weight: 500;
	}

	.filters-panel {
		display: grid;
		gap: 1.25rem;
		margin-bottom: 1.5rem;
		padding: 1.35rem;
		background: var(--color-surface);
		border: 0.5px solid var(--color-border);
		border-radius: var(--radius-md);
	}

	.chip-group {
		display: grid;
		gap: 0.55rem;
	}

	.chip-label {
		margin: 0;
		font-size: 0.74rem;
		letter-spacing: 0.12em;
		color: var(--color-muted);
	}

	.chip-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.chip {
		padding: 0.4rem 0.85rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: var(--color-bg);
		color: var(--color-muted);
		font: inherit;
		font-size: 0.78rem;
		letter-spacing: 0.06em;
		cursor: pointer;
		transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
	}

	.chip:hover,
	.chip.is-active {
		border-color: var(--color-accent);
		color: var(--color-accent);
		background: var(--color-accent-soft);
	}

	.results-count {
		margin: 0 0 1.25rem;
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		color: var(--color-muted);
	}

	.article-list {
		display: grid;
		gap: 1.25rem;
	}

	.empty-state {
		text-align: center;
		padding: 3rem 1.5rem;
		background: var(--color-surface);
		border: 1px dashed var(--color-border);
		border-radius: var(--radius-card);
	}

	.empty-state h2 {
		margin: 0 0 0.5rem;
		font-family: var(--font-title);
		font-size: 1.25rem;
	}

	.empty-state p {
		margin: 0 0 1.25rem;
		color: var(--color-muted);
	}

	@media (max-width: 768px) {
		.filters-panel {
			padding: 1rem;
		}

		.chip {
			font-size: 0.74rem;
			padding: 0.38rem 0.75rem;
		}
	}
</style>
